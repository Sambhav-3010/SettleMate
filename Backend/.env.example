# Server Configuration
PORT=5000
NODE_ENV=production

# Backend URL (Your AWS backend URL with protocol)
# Example: https://api.your-domain.com
BACKEND_URL=http://localhost:5000

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/settlemate

# Session (Use a strong random string)
SESSION_SECRET=your-session-secret-here

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Frontend URL (Your Vercel deployment URL)
# Example: https://your-app.vercel.app
FRONTEND_URL=http://localhost:3000

# IMPORTANT: For cross-domain cookies (Vercel + AWS):
# 1. Both frontend and backend MUST use HTTPS
# 2. Set NODE_ENV=production
# 3. Set FRONTEND_URL to your actual Vercel URL
# 4. Do NOT set COOKIE_DOMAIN (removed for cross-origin support)
