# Server Configuration
PORT=5000
NODE_ENV=production

# Backend URL (your deployed API base)
BACKEND_URL=https://api.your-domain.com

# Frontend URL(s)
FRONTEND_URL=https://app.your-domain.com
FRONTEND_URLS=https://app.your-domain.com

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/settlemate

# JWT Auth (HttpOnly cookie)
JWT_SECRET=replace-with-strong-random-secret
JWT_EXPIRES_IN=30d
AUTH_COOKIE_NAME=auth_token

# Fallback secret for legacy compatibility (optional if JWT_SECRET is set)
SESSION_SECRET=optional-legacy-secret

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
